{
  "name": "solar-aid-server",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "prestart": "npx --yes kill-port 5000",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:ui": "npm run test && (start test-report.html || open test-report.html || xdg-open test-report.html)",
    "test:performance": "npx artillery run load-test.yml"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-validator": "^7.0.0",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "twilio": "^5.12.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "artillery": "^2.0.11"
  }
}
